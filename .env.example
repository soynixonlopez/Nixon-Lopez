# --- SMTP (formularios de contacto y cotización) ---
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
CONTACT_EMAIL_TO=info@nixonlopez.com

# --- Supabase (panel admin + base de datos) ---
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Solo servidor: guardar cotizaciones desde /api/quote sin sesión de usuario
SUPABASE_SERVICE_ROLE_KEY=

# Opcional: debe coincidir con la función is_admin() en SQL (por defecto info@nixonlopez.com)
# ADMIN_EMAIL=info@nixonlopez.com
